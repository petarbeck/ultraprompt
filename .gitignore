# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Tauri / Rust
src-tauri/target/
src-tauri/gen/

# Local SQLite databases (dev)
# NB: the app's runtime DB lives in the OS app-data dir, not the repo. These
# patterns just make sure a stray dev DB (and its WAL/journal sidecars) can't
# be committed.
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Environment
.env
.env.*
!.env.example

# Local signing / App Store assets — certs, provisioning profiles, packages.
# NEVER commit these (private keys + signing material).
.appstore/
*.provisionprofile
*.p12
*.cer

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Claude Code local config — keep ONLY the dogfooded /ultraprompt command;
# ignore personal settings/state (session-naming hook, settings.local.json, etc.)
.claude/*
!.claude/commands/

# SDD progress ledger (scratch)
.superpowers/

# Internal dev notes + release runbook — kept local, out of the public repo
docs/superpowers/
TODO.md
INTERNAL.md
RELEASE.md
scripts/build-mas.sh

# Throwaway Playwright + sql.js verification harness (not shipped)
.harness/

# Ultraprompt runtime queue/done (created in a project working dir)
.ultraprompt/

# tauri icon also emits mobile icons; this app is desktop-only
src-tauri/icons/android/
src-tauri/icons/ios/
